rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidTaskStatus(status) {
      return status in ['open', 'accepted', 'in_progress', 'completed', 'cancelled'];
    }

    function isNotificationUnread() {
      return !('read' in resource.data) || resource.data.read == false;
    }

    function isNotificationReadUpdate() {
      return isNotificationUnread()
        && request.resource.data.read == true
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt'])
        );
    }

    // ─── users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    // ─── tasks ─────────────────────────────────────────────────────────────
    match /tasks/{taskId} {
      function isTaskParticipantById() {
        let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
        return isSignedIn() && (
          task.ownerUid == request.auth.uid
          || task.acceptedBy == request.auth.uid
        );
      }

      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.taskId == taskId
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerName is string
        && request.resource.data.title is string
        && request.resource.data.status == 'open'
        && isValidTaskStatus(request.resource.data.status);

      allow update: if isSignedIn() && (
        resource.data.ownerUid == request.auth.uid
        || resource.data.acceptedBy == request.auth.uid
        || (
          resource.data.status == 'open'
          && request.resource.data.acceptedBy == request.auth.uid
        )
      );

      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && resource.data.status == 'open';

      // Chat metadata: tasks/{taskId}/chat/meta
      match /chat/meta {
        allow read, create, update: if isTaskParticipantById();
        allow delete: if false;
      }

      // Messages: tasks/{taskId}/messages/{messageId}
      // (NOT chat/messages — that path is invalid alongside chat/meta)
      match /messages/{messageId} {
        function chatMetaActive() {
          let metaPath = /databases/$(database)/documents/tasks/$(taskId)/chat/meta;
          return exists(metaPath) && get(metaPath).data.status == 'active';
        }

        allow list: if isTaskParticipantById();
        allow get: if isTaskParticipantById();

        allow create: if isTaskParticipantById()
          && request.resource.data.messageId == messageId
          && request.resource.data.chatRoomId == taskId
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.receiverUid is string
          && request.resource.data.message is string
          && request.resource.data.messageType is string
          && chatMetaActive();

        allow update: if isTaskParticipantById()
          && (
            request.auth.uid == resource.data.receiverUid
            || request.auth.uid == resource.data.senderUid
          );

        allow delete: if false;
      }
    }

    // ─── notifications ─────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.notificationId == notificationId
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorName is string
        && request.resource.data.userId is string
        && request.resource.data.taskId is string
        && request.resource.data.eventType is string
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.read != true;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && isNotificationReadUpdate();

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
